# ---- Server ----
# Telegram bot token from @BotFather (required for real Telegram auth)
BOT_TOKEN=123456:ABC-DEF...

# Secret used to sign session JWTs (use a long random string)
JWT_SECRET=change-me-to-a-long-random-string

# Prisma datasource. SQLite by default; swap to a Postgres URL to use Postgres.
DATABASE_URL="file:./prisma/dev.db"

# HTTP/WebSocket port for the backend
PORT=3001

# Public URL of the web client (used for CORS)
WEB_URL=http://localhost:5173

# Set to 1 to allow logging in with a mock user WITHOUT Telegram (local dev only!)
DEV_AUTH=0

# ---- Web (Vite, must be prefixed with VITE_) ----
# Base URL of the backend
VITE_SERVER_URL=http://localhost:3001
# Mirror of DEV_AUTH for the client
VITE_DEV_AUTH=0
