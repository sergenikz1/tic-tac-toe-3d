# =====================================================================
#  ФУЛЛСТЕК-ПРИЛОЖЕНИЕ (apps/server отдаёт и API, и фронтенд apps/web)
# =====================================================================

# --- Runtime (читается Node-сервером во время работы) ---

# Токен Telegram-бота из @BotFather (нужен для реальной Telegram-авторизации)
BOT_TOKEN=123456:ABC-DEF...

# Секрет для подписи сессионных JWT (длинная случайная строка)
JWT_SECRET=change-me-to-a-long-random-string

# Directus, где хранятся игроки и матчи. Внутри Dokploy — внутренний хост
# Directus, снаружи — публичный URL (https://api.твойдомен).
DIRECTUS_URL=http://localhost:8055

# Статический admin-токен из Directus (он же ADMIN_TOKEN в env Directus).
DIRECTUS_TOKEN=paste-a-directus-static-admin-token

# Публичный URL приложения (для CORS). = домен фронтенда (apps/web).
WEB_URL=http://localhost:5173

# Порт сервера
PORT=3001

# 1 = разрешить вход без Telegram (mock-игрок) — ТОЛЬКО для локальной разработки!
DEV_AUTH=0

# --- Build-time (Vite вшивает в бандл фронта при сборке, префикс VITE_) ---

# Публичный URL бэкенда (apps/server). При РАЗДЕЛЬНОМ деплое фронта и сервера —
# ОБЯЗАТЕЛЬНО (напр. https://api.твойдомен). Локально: http://localhost:3001
VITE_SERVER_URL=http://localhost:3001
# Имя бота (без @) — включает нативный Telegram-шаринг кода-приглашения
VITE_BOT_USERNAME=
# Зеркало DEV_AUTH для клиента
VITE_DEV_AUTH=0
