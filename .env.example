# ---- Server ----
# Telegram bot token from @BotFather (required for real Telegram auth)
BOT_TOKEN=123456:ABC-DEF...

# Secret used to sign session JWTs (use a long random string)
JWT_SECRET=change-me-to-a-long-random-string

# Prisma datasource (PostgreSQL).
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# - Inside Dokploy (server deployed alongside the DB) HOST is the database App Name:
#     postgresql://postgres:PASSWORD@tictactoe3d-tictactoe3d:5432/tictactoe3d?schema=public
# - From your machine (running migrations) use the External host:port Dokploy shows:
#     postgresql://postgres:PASSWORD@YOUR_SERVER_IP:EXTERNAL_PORT/tictactoe3d?schema=public
DATABASE_URL="postgresql://postgres:PASSWORD@localhost:5432/tictactoe3d?schema=public"

# HTTP/WebSocket port for the backend
PORT=3001

# Public URL of the web client (used for CORS)
WEB_URL=http://localhost:5173

# Set to 1 to allow logging in with a mock user WITHOUT Telegram (local dev only!)
DEV_AUTH=0

# ---- Web (Vite, must be prefixed with VITE_) ----
# Base URL of the backend
VITE_SERVER_URL=http://localhost:3001
# Mirror of DEV_AUTH for the client
VITE_DEV_AUTH=0
# Bot username (without @) — enables native Telegram share deep links for invites
VITE_BOT_USERNAME=
